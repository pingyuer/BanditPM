watch_file pyproject.toml
watch_file uv.lock
watch_file .python-version

# Keep Miniconda as the host-level tool provider.
if [ -d "${HOME}/miniconda3/bin" ]; then
  PATH_add "${HOME}/miniconda3/bin"
fi

# Project-local Python environment managed by uv.
export PROJECT_ROOT="$PWD"
export UV_PROJECT_ENVIRONMENT="${PROJECT_ROOT}/.venv"
export VIRTUAL_ENV="${UV_PROJECT_ENVIRONMENT}"
PATH_add "${VIRTUAL_ENV}/bin"

# Make in-repo imports work consistently for tests and scripts.
export PYTHONPATH="${PROJECT_ROOT}${PYTHONPATH:+:${PYTHONPATH}}"

# Optional machine-local overrides.
source_env_if_exists .envrc.local
